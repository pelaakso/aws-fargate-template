{
  "name": "aws-lambda-templates",
  "version": "0.1.0",
  "bin": {
    "infra": "bin/infra.js"
  },
  "engines": {
    "node": ">22.0.0 <25.0.0",
    "pnpm": ">=10.16.0",
    "npm": "\n\nUse pnpm!!\n\n"
  },
  "scripts": {
    "all": "pnpm run eslint && pnpm run prettier && pnpm run test",
    "build": "tsc --noEmit",
    "clean": "pnpm exec rimraf '+(bin|lib|functions|test|utils)/**/+(*.d.ts|*.js)'",
    "eslint": "eslint .",
    "npm-check-updates": "npm-check-updates",
    "prettier": "prettier --check .",
    "watch": "tsc -w",
    "snap": "jest",
    "test": "pnpm run build && jest",
    "cdk": "cdk"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.34.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.18.1",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "aws-cdk": "^2.1027.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "jest": "^30.3.0",
    "npm-check-updates": "^19.6.3",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.243.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  }
}
